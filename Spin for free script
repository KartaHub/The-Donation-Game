-- Draggable functionality
local UserInputService = game:GetService("UserInputService")
local dragging = false
local dragInput, dragStart, startPos

local function update(input)
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

TitleLabel.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

TitleLabel.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		update(input)
	end
end)

-- Variables to track active loops
local infCreditActive = false
local infCreditThread = nil

local autoRedeemActive = false
local autoRedeemThread = nil

-- INF Credit Function
InfCreditButton.MouseButton1Click:Connect(function()
	infCreditActive = not infCreditActive
	
	if infCreditActive then
		-- Turn ON
		InfToggle.BackgroundColor3 = Color3.fromRGB(50, 205, 50)
		InfToggle.Text = "ON"
		
		-- Start the loop
		infCreditThread = task.spawn(function()
			while infCreditActive and task.wait() do
				local args = {
					"100000000000",
					1
				}
				game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Spin"):FireServer(unpack(args))
			end
		end)
	else
		-- Turn OFF
		InfToggle.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
		InfToggle.Text = "OFF"
		
		-- Stop the loop
		if infCreditThread then
			task.cancel(infCreditThread)
			infCreditThread = nil
		end
	end
end)

-- Auto Redeem Function
AutoRedeemButton.MouseButton1Click:Connect(function()
	autoRedeemActive = not autoRedeemActive
	
	if autoRedeemActive then
		-- Turn ON
		RedeemToggle.BackgroundColor3 = Color3.fromRGB(50, 205, 50)
		RedeemToggle.Text = "ON"
		
		-- Start the loop
		autoRedeemThread = task.spawn(function()
			while autoRedeemActive and task.wait() do
				local args = {
					"10000"
				}
				game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Withdraw"):FireServer(unpack(args))
			end
		end)
	else
		-- Turn OFF
		RedeemToggle.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
		RedeemToggle.Text = "OFF"
		
		-- Stop the loop
		if autoRedeemThread then
			task.cancel(autoRedeemThread)
			autoRedeemThread = nil
		end
	end
end)

